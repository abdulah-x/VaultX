# App Configuration
APP_NAME=Crypto Portfolio API
VERSION=1.0.0
DEBUG=true

# Server Configuration
HOST=127.0.0.1
PORT=8000

# Database Configuration (PostgreSQL — REQUIRED, no SQLite fallback)
DATABASE_URL=postgresql://crypto_user:crypto_password@localhost:5433/crypto_portfolio

# Security Configuration (CHANGE THESE IN PRODUCTION!)
# App refuses to start with this default value unless ALLOW_INSECURE_SECRET=true
# is explicitly set (only intended for quick throwaway local testing).
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# ALLOW_INSECURE_SECRET=true

# Emails allowed to hit privileged admin routes (DB backup/restore). Empty = none.
ADMIN_EMAILS=

# Public URL of the frontend (used in password-reset / verification links)
FRONTEND_URL=http://localhost:3100

# Google Gemini (LLM Portfolio Advisor). Get a free-tier key from
# https://aistudio.google.com/apikey. Server-side only, never sent to the frontend.
GEMINI_API_KEY=

# Binance API Configuration (get from Binance)
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_SECRET_KEY=your_testnet_secret_key_here
BINANCE_TESTNET=true

# Redis Configuration (for token blacklisting + OTP storage)
# Must match the password Redis is started with (see docker-compose.yml REDIS_PASSWORD).
REDIS_URL=redis://:changeme_dev_redis_password@localhost:6380/0

# Security Settings
ENABLE_API_ENCRYPTION=true
ALLOWED_IPS=localhost,127.0.0.1

# Rate Limiting
API_RATE_LIMIT_PER_MINUTE=60
BINANCE_RATE_LIMIT_PER_MINUTE=1000

# Emergency Controls
EMERGENCY_DISABLE_BINANCE=false
MAINTENANCE_MODE=false


SMTP_FROM_NAME=VaultX Crypto Portfolio

# CORS Configuration
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
