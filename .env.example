# Root-level environment file, read by docker-compose.yml's variable
# substitution (${VAR}) when building the backend/frontend services.
#
# This is DISTINCT from backend/.env.example — some values (Google OAuth,
# GEMINI_API_KEY, REDIS_PASSWORD) must exist in BOTH the root .env and
# backend/.env, or an unset root var can substitute in as an empty string
# and silently shadow the real value from the mounted backend/.env.

# Google OAuth (used by both backend and frontend build args)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Gemini (LLM Portfolio Advisor) — must match backend/.env's value
GEMINI_API_KEY=

# Redis password (defaults to changeme_dev_redis_password if unset — override for anything beyond local dev)
REDIS_PASSWORD=
